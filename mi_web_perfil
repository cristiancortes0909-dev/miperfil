<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil Pro</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background-color: #E3F2FD; display: flex; justify-content: center; padding: 20px; }
        .card { background: white; padding: 30px; border-radius: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); width: 100%; max-width: 400px; text-align: center; }
        h1 { color: #1565C0; }
        input, textarea { width: 90%; padding: 10px; margin: 10px 0; border: 1px solid #ddd; border-radius: 8px; }
        button { background: #1565C0; color: white; border: none; padding: 12px 25px; border-radius: 8px; cursor: pointer; font-weight: bold; }
        button:hover { background: #0D47A1; }
        .info-actual { margin-top: 20px; padding: 15px; background: #F5F5F5; border-radius: 10px; text-align: left; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Mi Perfil Personal</h1>
        <p id="userEmail" style="color: #666; font-size: 0.9em;">Cargando usuario...</p>
        
        <input type="text" id="nombre" placeholder="Tu Nombre Real">
        <input type="text" id="telefono" placeholder="Tu Teléfono">
        <textarea id="bio" placeholder="Cuéntanos sobre ti..."></textarea>
        
        <button onclick="guardarDatos()">GUARDAR CAMBIOS</button>

        <div class="info-actual">
            <strong>Tus Datos Guardados:</strong>
            <p id="mostrarNombre">Nombre: ---</p>
            <p id="mostrarTel">Tel: ---</p>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getFirestore, doc, setDoc, getDoc } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";
        import { getAuth, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js";

        const firebaseConfig = {
            apiKey: "AIzaSyDMHih5DwWZb0xcUUNwoINw8403Dvz_05U",
            authDomain: "perfiles-24555.firebaseapp.com",
            projectId: "perfiles-24555",
            storageBucket: "perfiles-24555.firebasestorage.app",
            messagingSenderId: "603890826240",
            appId: "1:603890826240:web:7b290eefc8eaaf3da12ce5"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const auth = getAuth(app);

        let uidActual = null;

        // Detectar automáticamente quién inició sesión en la App
        onAuthStateChanged(auth, async (user) => {
            if (user) {
                uidActual = user.uid; // Guardamos el ID único del usuario
                document.getElementById('userEmail').innerText = "Sesión: " + user.email;
                
                // Cargar solo los datos de ESTE usuario
                const docRef = doc(db, "usuarios", uidActual);
                const docSnap = await getDoc(docRef);
                if (docSnap.exists()) {
                    document.getElementById('mostrarNombre').innerText = "Nombre: " + docSnap.data().nombre;
                    document.getElementById('mostrarTel').innerText = "Tel: " + docSnap.data().telefono;
                }
            } else {
                document.getElementById('userEmail').innerText = "No has iniciado sesión";
                alert("Por seguridad, abre esta página desde la App.");
            }
        });

        window.guardarDatos = async () => {
            if (!uidActual) {
                alert("No hay un usuario identificado.");
                return;
            }

            const nom = document.getElementById('nombre').value;
            const tel = document.getElementById('telefono').value;
            
            try {
                // GUARDAR usando el UID como nombre del documento
                await setDoc(doc(db, "usuarios", uidActual), {
                    nombre: nom,
                    telefono: tel,
                    email: auth.currentUser.email
                });
                alert("¡Tus datos privados han sido guardados!");
                location.reload();
            } catch (e) {
                console.error(e);
                alert("Error de permisos. Revisa las reglas de Firestore.");
            }
        };
    </script>
</body>
</html>